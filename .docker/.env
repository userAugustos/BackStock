# Namespaces the compose project so containers/networks don't collide with other repos.
COMPOSE_PROJECT_NAME=store-pilot

# Host port overrides. Compose picks defaults when unset.
# This project uses SQLite (bun:sqlite) — no database container is required.
# RABBITMQ_HOST_PORT=5672
# RABBITMQ_UI_PORT=15672

# Named volume overrides (use a per-project prefix to avoid collisions).
# RABBITMQ_VOLUME=store-pilot-rabbitmq-data
