{
  "name": "@back-stock/api",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./days": {
      "types": "./dist/days.d.ts",
      "import": "./dist/days.js"
    },
    "./versions": {
      "types": "./dist/versions.d.ts",
      "import": "./dist/versions.js"
    },
    "./runs": {
      "types": "./dist/runs.d.ts",
      "import": "./dist/runs.js"
    },
    "./simulation": {
      "types": "./dist/simulation.d.ts",
      "import": "./dist/simulation.js"
    },
    "./compare": {
      "types": "./dist/compare.d.ts",
      "import": "./dist/compare.js"
    }
  },
  "scripts": {
    "build": "bun run build:sdk",
    "build:sdk": "tsup",
    "dev": "concurrently -n server,workers,sdk -c blue,green,cyan \"bun run dev:server\" \"bun run dev:workers\" \"bun run dev:sdk\"",
    "dev:server": "bun run --watch src/server.ts",
    "dev:workers": "bun run --watch src/workers.ts",
    "dev:sdk": "tsup --watch",
    "start": "bun run src/server.ts",
    "start:workers": "bun run ./src/workers.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test": "bun test --env-file .env --preload ./src/test/setup.ts",
    "test:e2e": "bun test --bail --timeout 30000 --env-file .env --env-file .env.test --preload ./src/test/setup.ts src/test/e2e.*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@elysiajs/eden": "^1.4.6",
    "zod": ">=3.25.3"
  },
  "dependencies": {
    "@elysiajs/cors": "1.4.1",
    "@elysiajs/openapi": "1.4.14",
    "drizzle-orm": "^0.36.0",
    "elysia": "1.4.22",
    "pino": "^10.1.1",
    "rabbitmq-client": "^5.0.8",
    "xstate": "^5",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@elysiajs/eden": "^1.4.6",
    "@back-stock/tsconfig": "workspace:*",
    "bun-types": "^1.3.2",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "zod": "^3.25.3"
  }
}
